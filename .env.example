# Whisper Model Configuration
# Options: tiny, base, small, medium, large
# Recommendation: 'tiny' for low-resource, 'base' for balanced, 'large' for accuracy
WHISPER_MODEL_SIZE=base

# Audio Processing
SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_FORMAT=wav

# Server Configuration
PORT=7865
HOST=0.0.0.0

# Output Configuration
# Set OUTPUT_DIR to save transcriptions (leave empty to disable)
OUTPUT_DIR=

# Temporary Files
TMP_DIR=tmp

# Performance Tuning (CPU)
WHISPER_CPU_THREADS=4
OMP_NUM_THREADS=4

# Logging
LOG_LEVEL=INFO
